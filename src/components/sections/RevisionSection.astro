---
import Kicker from '~/components/primitives/Kicker.astro';
import type { Locale } from '~/i18n';

interface Props {
  kicker: string;
  title: string;
  body: string;
  meta: { dates: string; venue: string; audience: string; edition: string };
  ctaLabel: string;
  ctaHref: string;
  locale: Locale;
  archiveNote?: string;
}
const { kicker, title, body, meta, ctaLabel, ctaHref, locale, archiveNote } = Astro.props;

const LABELS: Record<Locale, Record<'dates' | 'venue' | 'audience' | 'edition', string>> = {
  en: { dates: 'Dates', venue: 'Venue', audience: 'Audience', edition: 'Edition' },
  de: { dates: 'Termin', venue: 'Ort', audience: 'Publikum', edition: 'Ausgabe' },
};
const lbl = LABELS[locale];
---
<section class="revision" id="revision">
  <div class="container">
    <div class="card">
      <Kicker>{kicker}</Kicker>
      <div class="intro">
        <h2>{title}</h2>
        <img class="rev-logo" src="/revision-logo.svg" alt="Revision" loading="lazy" decoding="async" />
        <p class="body">{body}</p>
      </div>
      <dl class="meta">
        <div><dt>{lbl.dates}</dt><dd>{meta.dates}</dd></div>
        <div><dt>{lbl.venue}</dt><dd>{meta.venue}</dd></div>
        <div><dt>{lbl.audience}</dt><dd>{meta.audience}</dd></div>
        <div><dt>{lbl.edition}</dt><dd>{meta.edition}</dd></div>
      </dl>
      <a href={ctaHref} class="link">{ctaLabel}</a>
      {archiveNote && <p class="archive-note">{archiveNote}</p>}
    </div>
  </div>
</section>

<style>
  .revision { padding: 120px 0; }
  .container { max-width: 1320px; margin: 0 auto; padding: 0 40px; }
  .card {
    background: var(--color-ink); color: var(--color-paper);
    padding: 80px; border-radius: 4px;
  }
  /* Kicker on the dark card needs a visible rule + readable text. */
  .card :global(.kicker) { color: var(--color-rule); }
  .card :global(.kicker)::before { background: var(--color-rule); opacity: .5; }

  /* Grid holds title + body in column 1, logo in column 2 spanning
     both rows. That way the body paragraph sits snug under the title
     rather than below the logo's bottom edge. */
  .intro {
    margin-top: 20px;
    display: grid;
    grid-template-columns: 1fr auto;
    column-gap: 48px; row-gap: 24px;
    align-items: start;
  }
  .intro h2 {
    grid-column: 1; grid-row: 1;
    font-size: clamp(36px, 5vw, 72px);
    color: var(--color-paper);
    margin: 0;
  }
  .intro .rev-logo {
    grid-column: 2; grid-row: 1 / span 2;
    width: clamp(140px, 16vw, 220px); height: auto;
    align-self: start;
    margin-top: -4px;
  }
  .intro .body {
    grid-column: 1; grid-row: 2;
    margin: 0;
    font-size: clamp(16px, 1.15vw, 19px);
    max-width: 60ch;
    color: var(--color-rule);
    line-height: 1.55;
  }
  @media (max-width: 720px) {
    .intro {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .intro .rev-logo {
      grid-column: 1; grid-row: 1;
      width: 96px; justify-self: start;
      margin-top: 0;
    }
    .intro h2 { grid-row: 2; }
    .intro .body { grid-row: 3; }
  }
  .meta {
    margin-top: 48px;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;
    padding-top: 28px; border-top: 1px solid rgba(255,255,255,.15);
  }
  .meta dt {
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: .18em; text-transform: uppercase;
    color: var(--color-rule);
  }
  .meta dd {
    margin: 6px 0 0; font-family: var(--font-display);
    font-size: 18px; color: var(--color-paper);
  }
  .link {
    margin-top: 28px; display: inline-block;
    font-family: var(--font-display); font-style: italic;
    font-size: 22px; color: #eb6b7f;
    text-decoration: none;
  }
  .archive-note {
    margin-top: 18px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-rule);
    max-width: 60ch;
  }
  @media (hover: hover) {
    .link:hover { color: var(--color-paper); }
  }
  @media (max-width: 900px) { .meta { grid-template-columns: repeat(2, 1fr); } .card { padding: 40px 24px; } }
  @media (max-width: 720px) { .container { padding: 0 20px; } }
</style>
