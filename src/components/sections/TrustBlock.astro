---
import Kicker from '~/components/primitives/Kicker.astro';

interface Props { kicker: string; title: string; items: string[]; }
const { kicker, title, items } = Astro.props;
---
<section class="trust">
  <div class="container">
    <Kicker>{kicker}</Kicker>
    <h3>{title}</h3>
    <ul class="list">
      {items.map(item => <li>{item}</li>)}
    </ul>
  </div>
</section>

<style>
  .trust { padding: 64px 0; background: var(--color-paper-2); }
  .container { max-width: 1320px; margin: 0 auto; padding: 0 40px; }
  h3 { font-size: clamp(24px, 2.4vw, 34px); margin-top: 16px; }
  .list { margin-top: 24px; padding: 0; list-style: none; max-width: 70ch; }
  .list li {
    position: relative; padding-left: 28px; margin: 10px 0;
    color: var(--color-ink-2); line-height: 1.5;
  }
  .list li::before {
    content: "×"; position: absolute; left: 0;
    color: var(--color-muted); font-family: var(--font-mono); font-weight: 600;
  }
  @media (max-width: 720px) { .container { padding: 0 20px; } }
</style>
