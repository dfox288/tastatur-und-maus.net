---
import Kicker from '~/components/primitives/Kicker.astro';

interface Props { kicker: string; title: string; body: string; }
const { kicker, title, body } = Astro.props;
---
<section class="explainer">
  <div class="container">
    <Kicker>{kicker}</Kicker>
    <h2>{title}</h2>
    <p class="body">{body}</p>
  </div>
</section>

<style>
  .explainer { padding: 80px 0; background: var(--color-paper-2); }
  .container { max-width: 1320px; margin: 0 auto; padding: 0 40px; }
  h2 { font-size: clamp(32px, 4vw, 56px); margin-top: 20px; max-width: 22ch; }
  .body { margin-top: 28px; font-size: clamp(17px, 1.2vw, 20px); line-height: 1.6; color: var(--color-ink-2); max-width: 68ch; }
  @media (max-width: 720px) { .container { padding: 0 20px; } .explainer { padding: 56px 0; } }
</style>
